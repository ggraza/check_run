	"css": "@font-face {\n    font-family: 'MICR Encoding';\n    font-style: normal;\n    src: url(data:font/truetype;charset=utf-8;base64,)\n}\n\n.print-format {\n\tpadding: 0px;\n}\n\n@media screen {\n\t.print-format {\n\t\tpadding: 0in;\n\t}\n}\n\n#check_section_1 {\n    font-size: 15px;\n    width:20.0cm;\n    height:8.9cm;\n}\n\n#payer_check_window_block {\n    top: 0.1cm; \n    left: 1cm;\n    position: absolute;\n    width: 8.8cm;    \n    height: 2.2cm;\n}\n\n#payer_contact_block {\n    top: 0.2cm;\n    left: 0.2cm;\n    position: relative;\n}\n\n#check_date_block {\n    top:2.0cm;\n    right: 1.5cm;\n    position: absolute;\n    text-align: right;\n}\n\n#payee_name_block {\n    top:3.2cm;\n    left: 2.8cm;\n    position: absolute;\n    min-width: 6cm;\n}\n\n#payment_amount_number_block {\n    top:3.2cm;\n    right: 1.5cm;\n\tposition: absolute; \n\tmin-width: 4cm;\n    text-align: right;\n}\n\n#payment_in_words_block {\n    font-size: 13px;\n    top:4.05cm;\n    left:2.8cm;\n    position: absolute;\n    display: block;\n    width: 16.5cm;\n    line-height:0.5cm;\n    word-wrap: break-word;\n}\n\n#payee_address_window_block {\n    top:4.9cm;\n    left: 1.9cm;\n    position: absolute;  \n    width: 8.8cm; \n    height:2.2cm;\n}\n\n#payee_contact_block {\n    top: 0.2cm; \n    left: 0.2cm;\n    position: relative;\n}\n\n#memo_block {\n    font-size: 10px;\n    top:7.1cm;\n    left: 2.1cm;\n    position: absolute;  \n    width: 6cm;\n}\n\n#signature_block {\n    color: blue;\n    font-family: cursive;\n    top:7.1cm;\n    left:13.8cm;\n    position: absolute;\n    min-width: 6cm;\n}\n\n#micr_encoding_block {\n    top:7.9cm;\n    left:2.8cm;\n    position: absolute;\n    min-width: 13cm;\n}\n\n#check_section_2 {\n    top:9cm;\n    height:8.9cm;\n}\n\n.payment_reference_block {\n    padding-left:1cm; \n    padding-right:1cm; \n}\n\n.right_stamp {\n    top:2.8cm;\n    left: 16.6cm;\n    width: 3cm;\n\theight: 1.5cm;\n\tfont-size: 40px;\n  \tfont-weight: bold;\n    position: absolute; \n}\n\n.sig_stamp {\n    top:6.3cm;\n    left: 13.8cm;\n    width: 3cm;\n\theight: 1.5cm;\n\tfont-size: 40px;\n  \tfont-weight: bold;\n    position: absolute; \n}\n\n.big_stamp {\n    top:2.8cm;\n    left: 6.1cm;\n    width: 7cm;\n\theight: 3cm;\n\tfont-size: 80px;\n  \tfont-weight: bold;\n    position: absolute; \n}\n\n.stamp {\n\tmargin: 0px;\n\toverflow: hidden;\n    display: flex;\n    justify-content: space-around;\n    align-items: center;\n    vertical-align: middle;\n    text-align: center;\n\n    flex-direction: row;\n    color: #555;\n\tfont-weight: 700;\n\tborder: 0.25rem solid #555;\n\tdisplay: inline-block;\n\t\n\ttext-transform: uppercase;\n\tborder-radius: 1rem;\n\tfont-family: 'Courier';\n\t-webkit-mask-image: url('https://s3-us-west-2.amazonaws.com/s.cdpn.io/8399/grunge.png');\n    -webkit-mask-size: 944px 604px;\n    mix-blend-mode: multiply;\n}\n\n.is-nope {\n    color: #ff5858;\n    border: 0.5rem double #D23;\n  \t-webkit-mask-position: 2rem 3rem;\n}\n\n.is-draft {\n\tcolor: #ff5858;\n\tborder: 1rem double #ff5858;\n    font-size: 6rem;\n    font-family: \"Open sans\", Helvetica, Arial, sans-serif;\n    border-radius: 0;\n    padding: 0.5rem;\n}",
	"custom_format": 1,
	"default_print_language": "en",
	"disabled": 0,
	"doc_type": "Check Run",
