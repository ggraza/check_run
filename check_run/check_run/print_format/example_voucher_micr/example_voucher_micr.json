	"doctype": "Print Format",
	"font_size": 14,
	"html": "<div style=\"position: relative; top:0.0cm\">\n    <div id=\"check_section_1\">\n        {% if doc.docstatus == 0 %}\n        <span class=\"stamp right_stamp is-draft\">VOID DRAFT</span>\n        <span class=\"stamp sig_stamp is-draft\">VOID DRAFT</span>\n        {% elif doc.docstatus == 2 %}\n        <span class=\"stamp right_stamp is-nope\">VOID</span>\n        <span class=\"stamp sig_stamp is-nope\">VOID</span>\n        <span class=\"stamp big_stamp is-nope\">VOID</span>\n        {% endif %}\n\n        <span id=\"payer_check_window_block\">\n            <div id=\"payer_contact_block\">\n                {{ doc.company }} <br>\n                {% set co_address = frappe.get_all('Address', filters=[['Dynamic Link', 'link_doctype', '=', 'Company'],\n                ['Dynamic Link', 'link_name', '=', doc.company], [\"disabled\", \"=\", 0]], pluck='name',\n                order_by='is_primary_address DESC', limit=1) %}\n                {% if co_address %}\n                {{ frappe.get_doc('Address', co_address[0]).get_display() }}\n                {% endif %}\n            </div>\n        </span>\n\n        <span id=\"check_date_block\">\n            {{ doc.get_formatted('posting_date') }}\n        </span>\n\n        <span id=\"payee_name_block\">\n            {{ doc.party_name }}\n        </span>\n\n        <span id=\"payment_amount_number_block\">\n            {{ doc.get_formatted('paid_amount')[1:].strip() }}\n        </span>\n\n        <span id=\"payment_in_words_block\">\n            {% set money_in_words = frappe.utils.money_in_words(doc.paid_amount)[:-5] %}\n            {% if money_in_words|length < 90 %} {% set money_in_words=(money_in_words\n                + '************************************************************************' )[:100] %} {% endif %} {{\n                money_in_words }}\n        </span>\n\n        <span id=\"payee_address_window_block\">\n            <div id=\"payee_contact_block\">\n                {{ doc.party_name }} <br>\n                {% set party_address = frappe.get_all('Address', filters=[['Dynamic Link', 'link_doctype', '=',\n                doc.party_type], ['Dynamic Link', 'link_name', '=', doc.party], [\"disabled\", \"=\", 0]], pluck='name',\n                order_by='is_primary_address DESC', limit=1) %}\n                {% if party_address %}\n                {{ frappe.get_doc('Address', party_address[0]).get_display() }}\n                {% endif %}\n            </div>\n        </span>\n\n        <span id=\"memo_block\">\n            MEMO\n        </span>\n\n        <span id=\"signature_block\">\n            SIGNATURE\n\n        </span>\n\n        <span id=\"micr_encoding_block\" style=\"font-family: 'MICR Encoding';\">\n            a9006000101a 10987654321b{{ doc.reference_no }}\n        </span>\n    </div>\n</div>\n\n<div id=\"check_section_2\">\n    <div class=\"payment_reference_block\">\n        <table class=\"table table-responsive-sm\">\n            <tr>\n                <td colspan=\"2\">{{doc.party_name}}</td>\n                <td> {{ frappe.utils.formatdate(doc.reference_date) or '' }} </td>\n                <td style=\"text-align:right;\" colspan=\"2\"> {{doc.get_formatted(\"base_paid_amount\")}} </td>\n            </tr>\n            {% if doc.references|length > 6 %}\n            <!-- More than 6 references exceeds page size, convert to comma-separated list -->\n            </table>\n            <br>\n            {% for reference in doc.references %}\n            <span>{{ reference.reference_name }}</span>\n            {{ \", \" if not loop.last else \"\" }}\n            {% endfor %}\n            {% else %}\n            <!-- Enough space for table rows for each reference -->\n            <tr>\n                <th> Date </th>\n                <th style=\"text-align:left;\"> Reference </th>\n                <th style=\"text-align:center;\"> Amount </th>\n                <th style=\"text-align:right;\"> Payment </th>\n            </tr>\n            {% for reference in doc.references %}\n            <tr>\n                {% if reference.reference_doctype == 'Purchase Invoice' %}\n                <td>{{ frappe.utils.formatdate(frappe.db.get_value(reference.reference_doctype,\n                    reference.reference_name, \"bill_date\")) or \"&#160;\" }}</td>\n                <td style=\"text-align:left;\"> {{ frappe.db.get_value(reference.reference_doctype,\n                    reference.reference_name, \"bill_no\") or \"&#160;\" }}</td>\n                {% elif reference.reference_doctype == 'Sales Invoice' %}\n                <td style=\"text-align:left;\">{{ frappe.utils.formatdate(frappe.db.get_value(reference.reference_doctype,\n                    reference.reference_name, \"po_date\")) or \"&#160;\" }}</td>\n                <td style=\"text-align:left;\"> {{ frappe.db.get_value(reference.reference_doctype,\n                    reference.reference_name, \"po_no\") or \"&#160;\" }}</td>\n                {% elif reference.reference_doctype == 'Expense Claim' %}\n                <td style=\"text-align:left;\">{{ frappe.utils.formatdate(frappe.db.get_value(reference.reference_doctype,\n                    reference.reference_name, \"expense_report_date\")) or \"&#160;\" }}</td>\n                <td style=\"text-align:left;\"> {{ frappe.db.get_value(reference.reference_doctype,\n                    reference.reference_name, \"name\") or \"&#160;\" }}</td>\n                {% elif reference.reference_doctype == 'Journal Entry' %}\n                <td style=\"text-align:left;\"> {{\n                    frappe.utils.formatdate(frappe.db.get_value(reference.reference_doctype, reference.reference_name,\n                    \"posting_date\")) or \"&#160;\"}}</td>\n                <td style=\"text-align:left;\"> {{ frappe.db.get_value(reference.reference_doctype,\n                    reference.reference_name, \"name\") or \"&#160;\" }}</td>\n                {% endif %}\n                <td style=\"text-align:center;\"> {{ frappe.utils.fmt_money(reference.get_formatted('total_amount'), 2,\n                    'USD')}}</td>\n                <td style=\"text-align:right;\"> {{ reference.get_formatted('allocated_amount')}}</td>\n            </tr>\n            {% endfor %}\n        </table>\n        {% endif %}\n    </div>\n</div>",
